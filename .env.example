# ===========================================
# Daily Marketing Discovery — Environment
# ===========================================

# Путь к Obsidian или Tolaria vault.
# Заметки будут создаваться в {TOLARIA_VAULT_PATH}/marketing-discovery/
# Используй / даже на Windows: C:/Users/me/vault
# Если не задан — скилл спросит при запуске
TOLARIA_VAULT_PATH=

# Папка для заметок внутри vault (опционально)
# По умолчанию: marketing-discovery
TOLARIA_NOTES_DIR=marketing-discovery
